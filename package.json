{
  "name": "sentryward",
  "version": "0.1.10",
  "description": "Local-first security CLI for AI-generated code.",
  "type": "module",
  "homepage": "https://otimitare.online",
  "bugs": {
    "email": "suporte@otimitare.online"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gerlanss/sentryward.git"
  },
  "bin": {
    "ward": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "security",
    "cli",
    "ai-generated-code",
    "static-analysis",
    "secrets",
    "devsecops",
    "appsec",
    "code-review"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.3",
    "picocolors": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.1",
    "eslint": "^9.20.1",
    "prettier": "^3.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.5"
  }
}
